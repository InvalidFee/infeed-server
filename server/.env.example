# Copy to server/.env and fill in. Values here are dev defaults.

# Port the API listens on
PORT=3000

# Secret used to sign JWTs. MUST be set to a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Shared key the seed/admin tool sends in the x-admin-key header.
SEED_ADMIN_KEY=change-me-admin-key

# Length of the free trial in days (free tier is unlimited until it expires)
TRIAL_DAYS=14

# Optional: custom SQLite file path (defaults to server/infeed.db)
# DB_PATH=./infeed.db
