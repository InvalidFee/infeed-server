<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows plain HTTP only to local dev backends (LAN host 10.0.0.198,
  Android emulator host 10.0.2.2, and localhost). All other domains still
  require HTTPS. For production, point the app at an https:// API and these
  dev exceptions simply go unused.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.0.198</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
